<% if @chat.errors.any? %> <!-- Reemplaza @record por @user, @chat o @message según corresponda -->
  <div style="color: red; margin-bottom: 20px;">
    <h3>Errores:</h3>
    <ul>
      <% @chat.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<h1>New Chat</h1>

<%= form_with model: @chat do |f| %>
  <% if @chat.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(@chat.errors.count, "error") %> prohibited this chat from being saved:</h4>
      <ul>
        <% @chat.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :sender_id %>
    <%= f.select :sender_id, User.all.collect { |u| [u.email, u.id] }, {}, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= f.label :receiver_id %>
    <%= f.select :receiver_id, User.all.collect { |u| [u.email, u.id] }, {}, class: 'form-control' %>
  </div>

  <%= f.submit 'Create Chat', class: 'btn btn-primary' %>
  <%= link_to 'Cancel', chats_path, class: 'btn btn-secondary' %>
<% end %>