<div class="chat-details">
  <h1 class="mb-4">Detalles del Chat #<%= @chat.id %></h1>

  <div class="card mb-4">
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <h5 class="card-title">Remitente</h5>
          <p class="card-text">
            <%= @chat.sender.email %><br>
            <small class="text-muted"><%= @chat.sender.full_name %></small>
          </p>
        </div>
        <div class="col-md-6">
          <h5 class="card-title">Receptor</h5>
          <p class="card-text">
            <%= @chat.receiver.email %><br>
            <small class="text-muted"><%= @chat.receiver.full_name %></small>
          </p>
        </div>
      </div>
      <p class="card-text mt-3">
        <strong>Total mensajes:</strong> <%= @chat.messages.count %>
      </p>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h5 class="mb-0">Mensajes</h5>
    </div>
    <div class="card-body">
      <% if @chat.messages.any? %>
        <ul class="list-group">
          <% @chat.messages.each do |message| %>
            <li class="list-group-item">
              <div class="d-flex justify-content-between">
                <div>
                  <strong><%= message.user.email %>:</strong>
                  <span><%= message.body %></span>
                </div>
                <div>
                  <%= link_to 'Ver', chat_message_path(@chat, message), class: 'btn btn-sm btn-outline-primary' %>
                  <% if can?(:edit, message) %>
                    <%= link_to 'Editar', edit_chat_message_path(@chat, message), class: 'btn btn-sm btn-outline-secondary' %>
                  <% end %>
                </div>
              </div>
              <small class="text-muted">
                <%= message.created_at.strftime("%d/%m/%Y %H:%M") %>
              </small>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-muted">No hay mensajes en este chat</p>
      <% end %>
    </div>
  </div>

  <div class="mt-4">
    <% if can?(:edit, @chat) %>
      <%= link_to 'Editar Chat', edit_chat_path(@chat), class: 'btn btn-warning' %>
    <% end %>
    <%= link_to 'Volver', chats_path, class: 'btn btn-secondary' %>
    <% if can?(:create, Message) %>
      <%= link_to 'Nuevo Mensaje', new_chat_message_path(@chat), class: 'btn btn-success float-end' %>
    <% end %>
  </div>
</div>