<h1 class="mb-4">My Inbox</h1>

<% if can?(:create, Chat) %>
  <%= link_to 'New Chat', new_chat_path, class: 'btn btn-success mb-4' %>
<% end %>

<div class="table-responsive">
  <table class="table table-hover">
    <thead class="table-dark">
      <tr>
        <th>Conversation With</th>
        <th>Last Activity</th>
        <th>Messages</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if @chats.any? %>
        <% @chats.each do |chat| %>
          <tr>
            <td>
              <%= chat.other_participant(current_user).full_name %><br>
              <small class="text-muted"><%= chat.other_participant(current_user).email %></small>
            </td>
            <td>
              <%= chat.updated_at.to_formatted_s(:short) %>
            </td>
            <td>
              <%= chat.messages.count %>
            </td>
            <td>
              <div class="btn-group btn-group-sm" role="group">
                <%= link_to 'View', chat_path(chat), class: 'btn btn-primary' %>
                <% if can?(:edit, chat) %>
                  <%= link_to 'Edit', edit_chat_path(chat), class: 'btn btn-secondary' %>
                <% end %>
                <% if can?(:destroy, chat) %>
                  <%= link_to 'Delete', chat_path(chat),
                              method: :delete,
                              data: { confirm: 'Are you sure?' },
                              class: 'btn btn-danger' %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="4" class="text-center text-muted py-4">
            No chats available
            <% if can?(:create, Chat) %>
              <%= link_to 'Start new chat', new_chat_path, class: 'btn btn-link' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>