<%= form_with(model: message) do |form| %>
  <% if message.errors.any? %>
    <div class="alert alert-danger">
      <h2><%= pluralize(message.errors.count, "error") %> prohibited this message from being saved:</h2>
      <ul>
        <% message.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :chat_id %>
    <%= form.select :chat_id, Chat.all.collect { |c| ["Chat #{c.id} (Entre #{c.sender.email} y #{c.receiver.email})", c.id] }, {}, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :user_id, "Autor" %>
    <%= form.select :user_id, User.all.collect { |u| [u.email, u.id] }, {}, class: 'form-control' %>
  </div>

  <div class="form-group">
    <%= form.label :body, "Mensaje" %>
    <%= form.text_area :body, class: 'form-control' %>
  </div>

  <div class="actions">
    <%= form.submit "Guardar Mensaje", class: 'btn btn-primary' %>
  </div>
<% end %>