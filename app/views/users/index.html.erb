<h1 class="mb-4">Usuarios</h1>

<table class="table table-hover">
  <thead class="thead-dark">
    <tr>
      <th>Email</th>
      <th>Nombre</th>
      <th>Total Mensajes</th>
      <th>Última conexión</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.email %></td>
        <td><%= user.full_name %></td>
        <td><%= user.messages.size %></td>
        <td><%= time_ago_in_words(user.updated_at) %></td>
        <td>
          <div class="btn-group" role="group">
            <%= link_to 'Ver', user_path(user), class: 'btn btn-primary btn-sm' %>
            <% if can?(:edit, user) %>
              <%= link_to 'Editar', edit_user_path(user), class: 'btn btn-secondary btn-sm' %>
            <% end %>
            <% if can?(:destroy, user) %>
              <%= link_to 'Eliminar', user_path(user), 
                          method: :delete, 
                          data: { confirm: '¿Estás seguro?' },
                          class: 'btn btn-danger btn-sm' %>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="mt-3">
  <% if can?(:create, User) %>
    <%= link_to 'Nuevo Usuario', new_user_path, class: 'btn btn-success' %>
  <% end %>
</div>