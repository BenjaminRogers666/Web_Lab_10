<h1>Detalles del Usuario</h1>

<p><strong>Email:</strong> <%= @user.email %></p>
<p><strong>Nombre:</strong> <%= @user.first_name %></p>
<p><strong>Apellido:</strong> <%= @user.last_name %></p>

<h3>Chats del Usuario</h3>
<% if @chats.any? %>
  <ul>
    <% @chats.each do |chat| %>
      <li>
        Chat con <%= chat.sender_id == @user.id ? chat.receiver.email : chat.sender.email %>
        <%= link_to 'Ver chat', chat_path(chat) %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>El usuario no tiene chats.</p>
<% end %>

<%= link_to 'Volver', users_path, class: 'btn btn-secondary' %>