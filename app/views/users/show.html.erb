<div class="card">
  <div class="card-body">
    <h1><%= @user.full_name %></h1>
    <p class="text-muted"><%= @user.email %></p>
    
    <% if can?(:edit, @user) %>
      <%= link_to 'Edit Profile', edit_user_path(@user), class: 'btn btn-secondary' %>
    <% end %>
  </div>
</div>

<div class="row mt-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5>Conversations</h5>
      </div>
      <div class="card-body">
        <% if @chats.any? %>
          <ul class="list-group">
            <% @chats.each do |chat| %>
              <li class="list-group-item">
                <%= link_to chat.other_participant(@user).full_name, chat_path(chat) %>
                <span class="badge bg-primary rounded-pill float-end">
                  <%= chat.messages.count %>
                </span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted">No conversations yet</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h5>Recent Messages</h5>
      </div>
      <div class="card-body">
        <% if @user.messages.any? %>
          <ul class="list-group">
            <% @user.messages.order(created_at: :desc).limit(5).each do |message| %>
              <li class="list-group-item">
                <small class="text-muted"><%= message.created_at.to_formatted_s(:short) %></small><br>
                <%= truncate(message.body, length: 50) %><br>
                <small>in chat with <%= message.chat.other_participant(@user).full_name %></small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted">No messages sent yet</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="mt-3">
  <%= link_to 'Back', users_path, class: 'btn btn-outline-secondary' %>
</div>